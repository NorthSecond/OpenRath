# Copy to .env and fill in values. Never commit .env (see .gitignore).

# OpenAI API key (or compatible provider key)
OPENAI_API_KEY=

# API base URL (OpenAI default, or your gateway / proxy)
OPENAI_BASE_URL=https://api.openai.com/v1

# Default chat model when callers omit `model` (provider-specific id)
OPENAI_DEFAULT_MODEL=gpt-5.5

# --- OpenSandbox ---
# Server: use a TOML where [storage].allowed_host_paths permits the host paths you bind.
# Client: OPEN_SANDBOX_DOMAIN (default 127.0.0.1:8080), OPEN_SANDBOX_API_KEY if the server uses api_key.
# If create fails on host bind (e.g. HTTP 400/422 or allowlist mismatch), Rath retries without volumes unless RATH_OPENSANDBOX_STRICT_WORKSPACE_BIND=1.
# Mirror server api_key: set OPENSANDBOX_SERVER_API_KEY on the server side as well.
OPEN_SANDBOX_DOMAIN=127.0.0.1:8080
OPEN_SANDBOX_API_KEY=
OPENSANDBOX_SERVER_API_KEY=
